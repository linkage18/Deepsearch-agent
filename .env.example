# DeepSearch Agents 环境变量示例
# 复制为 .env 后按本机实际服务地址和密钥调整，不要提交真实密钥

# LLM 配置
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=你的大模型_API_KEY
LLM_QWEN_MAX=qwen-max

# 网络搜索配置
# 默认使用 Docker 内的 SearXNG（自托管，零额度）
# 如果 SearXNG 不在 Docker 内，可在此配置外部地址
# SEARXNG_BASE_URL=http://localhost:8888

# LlamaIndex 论文库配置
# 运行时数据统一写入 DATA_ROOT，Docker 中会挂载到 /app/data
DATA_ROOT=data
MODEL_CACHE_DIR=data/model_cache
# 默认读取 DATA_ROOT/papers，首次检索时自动构建索引并持久化到 DATA_ROOT/paper_index
LLAMAINDEX_PAPER_DIR=data/papers
LLAMAINDEX_INDEX_DIR=data/paper_index
LLAMAINDEX_SIMILARITY_TOP_K=5
# embedding 模式: mock(随机) | openai(需 API Key) | local(本地模型)
# 推荐 local（使用 sentence-transformers，已安装，不需额外费用）
LLAMAINDEX_EMBED_MODEL=local
ALLOW_MOCK_EMBEDDING=false
LLAMAINDEX_OPENAI_EMBED_MODEL=text-embedding-3-small
LLAMAINDEX_LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# 文档 chunk 大小（512 均衡大小文档，避免大 PDF 垄断召回）
LLAMAINDEX_CHUNK_SIZE=512
LLAMAINDEX_CHUNK_OVERLAP=64

# MySQL 配置
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=deepsearch_db
MYSQL_HOST=localhost
# docs/docker-compose.yaml 建议映射到 3307，避免和本机已有 MySQL 3306 冲突
MYSQL_PORT=3307
# 与初始化 SQL 和 Docker MySQL 服务保持一致，保证中文数据按 utf8mb4 读写
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_SQL_MODE=TRADITIONAL
