# === 后端 Dockerfile（单阶段构建） ===
#
# 构建：docker build -f docker/Dockerfile.backend -t deepsearch-backend .
# 单阶段避免重复拉取 base image（两阶段需要拉两次 python:3.12-slim）
# uv 用 pip 安装而非 COPY --from=ghcr.io（ghcr.io 在国内同样慢）

FROM python:3.12-slim

WORKDIR /app

# 安装编译依赖（torch/sentence-transformers 需要 gcc/g++）
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ && \
    rm -rf /var/lib/apt/lists/*

# 安装 uv——用 pip 而非从 ghcr.io 复制
RUN pip install uv --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple

# 先复制依赖声明，利用 Docker 层缓存
COPY pyproject.toml uv.lock ./

# 安装依赖（含 sentence-transformers→torch，构建时安装一次，约 5-8 分钟）
RUN uv sync --frozen --no-cache 2>&1

# 预下载 embedding 和 reranker 模型，避免运行时从 HuggingFace 下载
RUN .venv/bin/python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')" 2>&1

# 复制源码
COPY app/ ./app/
COPY docs/ ./docs/
COPY .env.example ./

# 运行时目录
RUN mkdir -p output updated app/storage

EXPOSE 8000

CMD [".venv/bin/uvicorn", "app.api.server:app", "--host", "0.0.0.0", "--port", "8000"]
