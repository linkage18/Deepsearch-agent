*.pyc
*.pyo

# IDE
.vscode/
.idea/
*.swp
*.swo

# 环境变量（密钥，不应进入镜像）
.env

# 操作系统
.DS_Store
Thumbs.db

# 文档（运行时不需要）
docs/images/
examples/

# 日志
*.log

